/***************************************
 * Shared HTML Helpers
 ***************************************/

function v2_wrapViewerHtml_(title, subtitle, bodyHtml) {
  return `
    <!DOCTYPE html>
    <html>
      <head>
        <base target="_top">
        ${v2_viewerStyles_()}
      </head>
      <body>
        <div class="wrapper">
          <div class="toolbar no-print">
            <button onclick="window.print()">Print / Save as PDF</button>
          </div>

          <div class="header">
            <h1>${title}</h1>
            <p>${subtitle}</p>
          </div>

          ${bodyHtml}

          <div class="footer no-print">
            <button onclick="google.script.host.close()">Close</button>
          </div>
        </div>
      </body>
    </html>
  `;
}

function v2_section_(title, fields, record) {
  return `
    <div class="section">
      <h2>${title}</h2>
      <div class="grid">
        ${fields.map(field => v2_infoRow_(record, field)).join('')}
      </div>
    </div>
  `;
}

function v2_infoRow_(record, label) {
  return `
    <div class="info-row">
      <div class="label">${label}</div>
      <div class="value">${v2_field_(record, label)}</div>
    </div>
  `;
}

function v2_contentBlock_(record, title, subjectField, bodyField) {
  return `
    <div class="content-block">
      <h3>${title}</h3>
      <div class="subject"><strong>Subject:</strong> ${v2_field_(record, subjectField)}</div>
      <div class="body">${v2_field_(record, bodyField)}</div>
    </div>
  `;
}

function v2_textBlock_(record, field) {
  return `
    <div class="content-block">
      <h3>${field}</h3>
      <div class="body">${v2_field_(record, field)}</div>
    </div>
  `;
}
function v2_longTextBlock_(record, field) {
  return `
    <div class="content-block">
      <h3>${field}</h3>
      <div class="body">${v2_field_(record, field)}</div>
    </div>
  `;
}
function v2_field_(record, label) {
  const value = record[label];

  if (value === null || value === undefined || value === '') {
    return '<span class="muted">Not populated</span>';
  }

  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/\n/g, '<br>');
}

