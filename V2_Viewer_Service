function v2_buildPromptViewerHtml_(record, rowNumber) {
  const promptText = record['Prompt Text'] || '';
  const inputVariables = record['Input Variables'] || '';

  return v2_wrapViewerHtml_(
    'Prompt Viewer',
    `${v2_field_(record, 'Prompt Name')} — Row ${rowNumber}`,
    `
    <div class="summary-cards">
      <div class="summary-card">
        <div class="summary-label">Prompt ID</div>
        <div class="summary-value">${v2_field_(record, 'Prompt ID')}</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Status</div>
        <div class="summary-value">${v2_field_(record, 'Status')}</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Version</div>
        <div class="summary-value">${v2_field_(record, 'Version')}</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Last Updated</div>
        <div class="summary-value">${v2_field_(record, 'Last Updated')}</div>
      </div>
    </div>

    ${v2_section_('Prompt Summary', [
      'Prompt ID',
      'Prompt Name',
      'Description',
      'Status',
      'Version',
      'Last Updated',
      'Notes'
    ], record)}

    <div class="section">
      <h2>Input Variables</h2>
      <div class="variable-list">
        ${v2_renderPromptVariables_(inputVariables)}
      </div>
    </div>

    <div class="section">
      <h2>Prompt Statistics</h2>
      <div class="grid">
        <div class="info-row">
          <div class="label">Characters</div>
          <div class="value">${promptText.length}</div>
        </div>
        <div class="info-row">
          <div class="label">Words</div>
          <div class="value">${v2_countWords_(promptText)}</div>
        </div>
        <div class="info-row">
          <div class="label">Approx Tokens</div>
          <div class="value">${Math.ceil(promptText.length / 4)}</div>
        </div>
        <div class="info-row">
          <div class="label">Variables Listed</div>
          <div class="value">${v2_countPromptVariables_(inputVariables)}</div>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Prompt Text</h2>
      <pre class="prompt-block">${v2_escapeHtml_(promptText)}</pre>
    </div>
    `
  );
}
function v2_renderPromptVariables_(inputVariables) {
  if (v2_isBlank(inputVariables)) {
    return '<span class="muted">No input variables listed</span>';
  }

  return String(inputVariables)
    .split(',')
    .map(item => item.trim())
    .filter(Boolean)
    .map(item => `<span class="variable-pill">${v2_escapeHtml_(item)}</span>`)
    .join('');
}

function v2_countPromptVariables_(inputVariables) {
  if (v2_isBlank(inputVariables)) return 0;

  return String(inputVariables)
    .split(',')
    .map(item => item.trim())
    .filter(Boolean)
    .length;
}

function v2_countWords_(text) {
  if (v2_isBlank(text)) return 0;

  return String(text)
    .trim()
    .split(/\s+/)
    .filter(Boolean)
    .length;
}

function v2_escapeHtml_(value) {
  if (value === null || value === undefined) return '';

  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}
