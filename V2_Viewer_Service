 * Prospect Viewer
 ***************************************/

function v2_buildProspectViewerHtml_(record, rowNumber) {
  return v2_wrapViewerHtml_(
    'Prospect Viewer',
    `${v2_field_(record, 'Company Name')} — Row ${rowNumber}`,
    `
    ${v2_section_('Prospect Information', [
      'Prospect ID', 'Date Added', 'Source', 'Company Name', 'Website',
      'Industry', 'Location', 'Employee Size', 'Turnover Estimate'
    ], record)}

    ${v2_section_('Contact Information', [
      'Contact Name', 'Job Title', 'Email Address', 'Corporate Phone', 'LinkedIn URL'
    ], record)}

    ${v2_section_('Processing', [
      'Offer Type', 'Data Completeness Score', 'Duplicate Check Status',
      'Ready For AI', 'Process Status', 'Last Updated', 'Notes'
