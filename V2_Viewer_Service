function v2_viewSelectedProspect() {
  v2_showSelectedRecordViewer_({
    requiredSheet: V2_CONFIG.SHEETS.PROSPECT_QUEUE,
    title: 'Selected Prospect Record',
    builder: v2_buildProspectViewerHtml_
  });
}

function v2_viewSelectedAIResearch() {
  v2_showSelectedRecordViewer_({
    requiredSheet: V2_CONFIG.SHEETS.AI_INTELLIGENCE,
    title: 'Selected AI Research Record',
    builder: v2_buildAIResearchViewerHtml_
  });
}

function v2_viewSelectedOutreachRecord() {
  v2_showSelectedRecordViewer_({
    requiredSheet: V2_CONFIG.SHEETS.AI_OUTREACH,
    title: 'Selected Outreach Record',
    builder: v2_buildOutreachViewerHtml_
  });
}

function v2_showSelectedRecordViewer_(config) {
  const sheet = SpreadsheetApp.getActiveSheet();
  const ui = SpreadsheetApp.getUi();

  if (sheet.getName() !== config.requiredSheet) {
    ui.alert(`Please select a row on the ${config.requiredSheet} tab first.`);
    return;
  }

  const row = sheet.getActiveRange().getRow();

  if (row < V2_CONFIG.FIRST_DATA_ROW) {
    ui.alert('Please select a data row, not the header or button row.');
    return;
  }

  const record = v2_getRowAsObject(sheet, row);
  const html = config.builder(record, row);

  ui.showModalDialog(
    HtmlService.createHtmlOutput(html).setWidth(950).setHeight(750),
    config.title
  );
}

