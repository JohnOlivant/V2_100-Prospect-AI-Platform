/***************************************
 * 100 Prospect AI Platform
 * V2_AI_Outreach_Service.gs
 * Generates outreach assets from approved AI Intelligence records
 ***************************************/

function v2_generateOutreachAssets() {
  const intelligenceSheet = v2_getConfiguredSheet('AI_INTELLIGENCE');
  const outreachSheet = v2_getConfiguredSheet('AI_OUTREACH');

  const intelligenceRecords = v2_getDataAsObjects(intelligenceSheet);

  const approvedRecords = intelligenceRecords.filter(row => {
    return (
      v2_normaliseText(row['Human Review Status']) === 'approved' &&
      !v2_outreachAlreadyExists_(outreachSheet, row['Prospect ID'])
    );
  });

  if (approvedRecords.length === 0) {
    v2_logInfo(
      '',
      'AI Outreach Service',
      'v2_generateOutreachAssets',
      'NO_APPROVED_RECORDS',
      'No approved AI intelligence records found for outreach generation.',
      '',
      ''
    );

    return {
      processed: 0,
      failed: 0,
      message: 'No approved AI intelligence records found for outreach generation.'
    };
  }

  let processed = 0;
  let failed = 0;

  approvedRecords.forEach(record => {
    try {
      v2_generateSingleOutreachAsset_(outreachSheet, record);
      processed++;
    } catch (error) {
      failed++;

      v2_logException(
        record['Prospect ID'] || '',
        'AI Outreach Service',
        'v2_generateOutreachAssets',
        error,
        JSON.stringify(record),
        ''
      );
    }
  });

  v2_logInfo(
    '',
    'AI Outreach Service',
    'v2_generateOutreachAssets',
    'BATCH_COMPLETE',
    `Outreach generation complete. Processed: ${processed}. Failed: ${failed}.`,
    '',
    ''
  );

  return {
    processed: processed,
    failed: failed,
    message: `Outreach generation complete. Processed: ${processed}. Failed: ${failed}.`
  };
}


function v2_generateSingleOutreachAsset_(outreachSheet, intelligenceRecord) {
  const prospectId = intelligenceRecord['Prospect ID'];
  const offerType = intelligenceRecord['Recommended Offer Type'] || '';

  if (v2_isBlank(prospectId)) {
    throw new Error('Prospect ID is missing from AI Intelligence record.');
  }

  if (v2_isBlank(offerType)) {
    throw new Error(`Recommended Offer Type is missing for prospect ${prospectId}`);
  }

  const promptId = v2_getPromptIdForWorkflow('Outreach', offerType);
const prompt = v2_getPromptById(promptId);
  const validation = v2_validatePrompt(prompt);

  if (!validation.valid) {
    throw new Error(
      `Outreach prompt is invalid. Missing fields: ${validation.missingFields.join(', ')}`
    );
  }

  const variables = v2_buildPromptVariablesFromRow(intelligenceRecord);
  const mergedPrompt = v2_mergePrompt(prompt['Prompt Text'], variables);

  const model = v2_getDefaultAIModel();
const temperature = v2_getOutreachTemperature();
const maxTokens = v2_getOutreachMaxTokens();

  v2_logInfo(
    prospectId,
    'AI Outreach Service',
    'v2_generateSingleOutreachAsset_',
    'PROCESS_STARTED',
    'Started outreach asset generation.',
    mergedPrompt,
    ''
  );

  const aiResponse = v2_callOpenAIJson({
    model: model,
    input: mergedPrompt,
    temperature: temperature,
    maxTokens: maxTokens
  });

  const outreach = aiResponse.json;

  const outreachAssetId = v2_getNextOutreachAssetId();
  const campaignId = v2_getNextCampaignId();

  const outreachRecord = v2_buildOutreachAssetRecord_({
    outreachAssetId: outreachAssetId,
    campaignId: campaignId,
    intelligenceRecord: intelligenceRecord,
    outreach: outreach,
    prompt: prompt,
    model: model
  });

  v2_appendObjectRow(outreachSheet, outreachRecord);

  v2_logInfo(
    prospectId,
    'AI Outreach Service',
    'v2_generateSingleOutreachAsset_',
    'PROCESS_COMPLETE',
    'Outreach asset generated and written to AI Outreach Asset Repository.',
    mergedPrompt,
    JSON.stringify(outreach)
  );
}


