function v2_outreachAlreadyExists_(outreachSheet, prospectId) {
  if (v2_isBlank(prospectId)) return false;

  const matches = v2_findRowsByField(outreachSheet, 'Prospect ID', prospectId);
  return matches.length > 0;
}
