/**
 * Replaces placeholders inside prompt text.
 *
 * Supports:
 * {{Company Name}}
 * {{company_name}}
 * [Company Name]
 * [company_name variable]
 */
function v2_mergePrompt(promptText, variables) {
  if (v2_isBlank(promptText)) {
    throw new Error('Prompt text is blank.');
  }

  variables = variables || {};

  let merged = String(promptText);

  Object.keys(variables).forEach(key => {
    const value = variables[key] === null || variables[key] === undefined
      ? ''
      : String(variables[key]);

    const snakeKey = v2_toSnakeCase_(key);

    const patterns = [
      new RegExp('{{\\s*' + v2_escapeRegExp_(key) + '\\s*}}', 'gi'),
      new RegExp('{{\\s*' + v2_escapeRegExp_(snakeKey) + '\\s*}}', 'gi'),
      new RegExp('\\[\\s*' + v2_escapeRegExp_(key) + '\\s*\\]', 'gi'),
      new RegExp('\\[\\s*' + v2_escapeRegExp_(snakeKey) + '\\s*\\]', 'gi'),
      new RegExp('\\[\\s*' + v2_escapeRegExp_(key) + '\\s+variable\\s*\\]', 'gi'),
      new RegExp('\\[\\s*' + v2_escapeRegExp_(snakeKey) + '\\s+variable\\s*\\]', 'gi')
    ];

    patterns.forEach(pattern => {
      merged = merged.replace(pattern, value);
    });
  });

  return merged;
}


/**
 * Converts common sheet row fields into prompt variables.
 */
function v2_buildPromptVariablesFromRow(rowObject) {
  const variables = {};

  Object.keys(rowObject).forEach(key => {
    if (key === '_rowNumber') return;

    variables[key] = rowObject[key];
    variables[v2_toSnakeCase_(key)] = rowObject[key];
  });

  return variables;
}


/**
 * Validates that a prompt has core required fields.
 */
function v2_validatePrompt(prompt) {
  const requiredFields = [
    'Prompt ID',
    'Prompt Name',
    'Prompt Category',
    'Workflow Stage',
    'Prompt Text',
    'Model'
  ];

  const missing = requiredFields.filter(field => v2_isBlank(prompt[field]));

  return {
    valid: missing.length === 0,
    missingFields: missing
  };
}


/**
 * Converts text to snake_case.
 */
function v2_toSnakeCase_(value) {
  return String(value || '')
    .trim()
    .replace(/([a-z])([A-Z])/g, '$1_$2')
    .replace(/[^a-zA-Z0-9]+/g, '_')
    .replace(/^_+|_+$/g, '')
    .toLowerCase();
}


/**
 * Escapes special characters for RegExp construction.
 */
function v2_escapeRegExp_(value) {
  return String(value || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}


/**
 * Test 1: test retrieval by prompt ID.
 * Change TEST_PROMPT_ID to one that exists in your Prompt Library.
 */
function v2_testPromptById() {
  const TEST_PROMPT_ID = 'PR-001';

  const prompt = v2_getPromptById(TEST_PROMPT_ID);
  const validation = v2_validatePrompt(prompt);

  v2_logInfo(
    '',
    'Prompt Service',
    'v2_testPromptById',
    'TEST',
    `Prompt retrieved: ${prompt['Prompt ID']} - ${prompt['Prompt Name']}`,
    '',
    JSON.stringify(validation)
  );

  SpreadsheetApp.getUi().alert(
    `Prompt Service Test Complete\n\n` +
    `Prompt ID: ${prompt['Prompt ID']}\n` +
    `Prompt Name: ${prompt['Prompt Name']}\n` +
    `Valid: ${validation.valid}\n` +
    `Missing Fields: ${validation.missingFields.join(', ') || 'None'}`
  );
}


/**
 * Test 2: test merge logic.
 */
function v2_testPromptMerge() {
  const promptText =
    'Analyse {{Company Name}} based in [Location]. Contact: [contact_name variable]. Offer: {{offer_type}}.';

  const variables = {
    'Company Name': 'Example Ltd',
    'Location': 'Hull',
    'Contact Name': 'Jane Smith',
    'Offer Type': 'Business Diagnostics'
  };

  const merged = v2_mergePrompt(promptText, variables);

  v2_logInfo(
    '',
    'Prompt Service',
    'v2_testPromptMerge',
    'TEST',
    'Prompt merge test completed.',
    promptText,
    merged
  );

  SpreadsheetApp.getUi().alert(
    `Prompt Merge Test Complete\n\n${merged}`
  );
}
