/**
 * Returns all prompt rows as objects.
 */
function v2_getAllPrompts() {
  const sheet = v2_getConfiguredSheet('PROMPT_LIBRARY');
  return v2_getDataAsObjects(sheet);
}


/**
 * Gets a prompt by Prompt ID.
 */
function v2_getPromptById(promptId) {
  if (v2_isBlank(promptId)) {
    throw new Error('Prompt ID is required.');
  }

  const prompts = v2_getAllPrompts();

  const prompt = prompts.find(row => {
    return String(row['Prompt ID']).trim() === String(promptId).trim();
  });

  if (!prompt) {
    throw new Error(`Prompt not found: ${promptId}`);
  }

  return prompt;
}


/**
 * Finds the best active approved V2 prompt based on filters.
 *
 * filters can include:
 * - promptCategory
 * - offerType
 * - workflowStage
 * - triggerEvent
 * - usedIn
 */
function v2_findPrompt(filters) {
  filters = filters || {};

  const prompts = v2_getAllPrompts();

  const matches = prompts.filter(prompt => {
    const activeStatus = v2_normaliseText(prompt['Active Status']);
    const promptStatus = v2_normaliseText(prompt['Prompt Status']);
    const usedIn = v2_normaliseText(prompt['Used In']);

    if (activeStatus !== 'active') return false;
    if (promptStatus !== 'approved') return false;

    if (filters.usedIn) {
      const requiredUsedIn = v2_normaliseText(filters.usedIn);
      if (!(usedIn === requiredUsedIn || usedIn === 'both')) return false;
    } else {
      if (!(usedIn === 'v2' || usedIn === 'both')) return false;
    }

    if (filters.promptCategory) {
      if (v2_normaliseText(prompt['Prompt Category']) !== v2_normaliseText(filters.promptCategory)) {
        return false;
      }
    }

    if (filters.offerType) {
      if (v2_normaliseText(prompt['Offer Type']) !== v2_normaliseText(filters.offerType)) {
        return false;
      }
    }

    if (filters.workflowStage) {
      if (v2_normaliseText(prompt['Workflow Stage']) !== v2_normaliseText(filters.workflowStage)) {
        return false;
      }
    }

    if (filters.triggerEvent) {
      if (v2_normaliseText(prompt['Trigger Event']) !== v2_normaliseText(filters.triggerEvent)) {
        return false;
      }
    }

    return true;
  });

  if (matches.length === 0) {
    throw new Error(
      'No active approved V2 prompt found for filters: ' +
      JSON.stringify(filters)
    );
  }

  if (matches.length > 1) {
    // Sort by version descending if possible, otherwise use first match.
    matches.sort((a, b) => {
      const versionA = Number(String(a['Version']).replace(/[^\d.]/g, '')) || 0;
      const versionB = Number(String(b['Version']).replace(/[^\d.]/g, '')) || 0;
      return versionB - versionA;
    });
  }

  return matches[0];
}


/**
 * Gets the active research prompt for an offer type.
 */
function v2_getResearchPrompt(offerType) {
  return v2_findPrompt({
    promptCategory: 'Research',
    offerType: offerType,
    workflowStage: 'Prospect Research',
    usedIn: 'V2'
